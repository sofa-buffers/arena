{
  "name": "SofaBuffers Arena (multi-language)",
  "build": { "dockerfile": "Dockerfile" },
  // Load local secrets (GitHub token) from .devcontainer/.env.
  // Copy .env.example to .env first; the real .env is gitignored.
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.devcontainer/.env"],
  "onCreateCommand": "./scripts/bootstrap.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "zxh404.vscode-proto3",
        "golang.go",
        "rust-lang.rust-analyzer",
        "redhat.java",
        "ms-dotnettools.csharp",
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "anthropic.claude-code"
      ]
    }
  }
}

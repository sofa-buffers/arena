# === Reference clones (not part of this repo) ================================
/generator/

# === Local editor / agent config & crash dumps ===============================
.claude*
core
*.core

# === Bootstrapped tooling & vendored corelibs (fetched by scripts/bootstrap.sh)
/tools/
/vendor/

# === Per-language build outputs ==============================================
# Generated *source* (protoc / sofabgen output) IS committed so the repo is
# browsable and usable without a regen; only heavy derived build outputs below
# are ignored. setup.sh regenerates the source on demand.
languages/**/target/
languages/**/bin/
languages/**/obj/
languages/**/build/
languages/**/node_modules/
languages/**/dist/
languages/**/zig-out/
languages/**/.zig-cache/
languages/**/__pycache__/
languages/**/*.class
languages/**/*.jar
languages/**/*.o
languages/**/*.exe
# compiled bench executables (no extension) live next to their sources
# (any impl subdir: sofab/, protobuf/, nanopb/, embeddedproto/, micropb/, ...)
languages/*/*/bench
# ...except the C# sofab bench, which is a source project directory (not a
# compiled binary). Keep its sources; still ignore its build output.
!languages/csharp/sofab/bench/
languages/csharp/sofab/bench/bin/
languages/csharp/sofab/bench/obj/
# EmbeddedProto is GPLv3: its generated code (derives from the GPL runtime) is
# regenerated by setup.sh and never committed — only our own driver/proto are.
languages/*/embeddedproto/gen/
Cargo.lock

# === Benchmark run artifacts =================================================
/results/raw/

# === Secrets =================================================================
.env
*.env
/scratchpad/
